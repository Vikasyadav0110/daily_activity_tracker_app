# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# PostHog (optional analytics — users must opt-in)
POSTHOG_API_KEY=phc_your_posthog_key
POSTHOG_HOST=https://app.posthog.com

# EAS (filled automatically by EAS Build)
# EXPO_PUBLIC_APP_ENV=development|staging|production

# Supabase — REQUIRED for Phase 2 features (auth, sync, social, payments)
# Note: EXPO_PUBLIC_ prefix is required for Expo to expose these to the JS bundle
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Razorpay — set in Supabase Edge Function secrets, NOT here (never expose key_secret in client)
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx  (server-side only — set via: supabase secrets set)
